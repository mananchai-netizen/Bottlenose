# === Neon DB (PostgreSQL) ===
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# === Auth ===
AUTH_SECRET=change-me-to-a-random-secret

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# === LINE Notify (optional - สำหรับ push notification) ===
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# === Anthropic (Claude AI) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === GitHub API dev publish mode (optional) ===
GITHUB_TOKEN=github_pat_your_token_here

# === Server ===
PORT=3000

# === Agent Personality ===
AGENT_NAME=MyAssistant
AGENT_SYSTEM_PROMPT=คุณคือผู้ช่วย AI อัจฉริยะที่ตอบสนองผ่าน LINE ตอบเป็นภาษาไทยหรือภาษาอังกฤษตามที่ผู้ใช้ถาม ตอบกระชับ ชัดเจน และเป็นประโยชน์
